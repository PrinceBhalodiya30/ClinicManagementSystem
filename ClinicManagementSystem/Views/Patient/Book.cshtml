@model ClinicManagementSystem.Models.BookAppointmentRequest
@{
    ViewData["Title"] = "Book Appointment";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="mb-4">
            <a asp-action="Index" class="text-decoration-none text-muted small">
                <i class="bi bi-arrow-left me-1"></i>Back
            </a>
            <h3 class="fw-bold mt-2">Book Slot</h3>
            <p class="text-muted small">Select your consultation time.</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger border shadow-sm mb-4">
                @ViewBag.Error
            </div>
        }

        <div class="card border shadow-sm">
            <div class="card-body p-4">
                <form asp-action="Book" method="post">
                    <div class="mb-3">
                        <label class="form-label fw-bold small">Date</label>
                        <input asp-for="Date" type="date" class="form-control" 
                               min="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold small">Time Slot</label>
                        <div class="row g-2">
                            @foreach (var slot in new[] { "09:00 AM", "10:00 AM", "11:00 AM", "12:00 PM", "02:00 PM", "03:00 PM", "04:00 PM" })
                            {
                                <div class="col-4">
                                    <input type="radio" class="btn-check" name="Slot" id="slot-@slot" value="@slot" required>
                                    <label class="btn btn-outline-primary btn-sm w-100 py-2" for="slot-@slot">@slot</label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary shadow-sm">
                            Confirm Appointment
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
