<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CMS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        :root {
            --primary: #0062ff;
            --bg-light: #f8f9fa;
        }

        body {
            font-family: 'Outfit', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            background-color: var(--bg-light);
            color: #333;
        }

        .navbar {
            background-color: #fff !important;
            border-bottom: 1px solid #dee2e6;
            padding: 1rem 0;
        }

        .navbar-brand {
            font-weight: 700;
            color: var(--primary) !important;
        }

        .nav-link {
            font-weight: 500;
            color: #555 !important;
            padding: 0.5rem 1rem !important;
        }

        .nav-link:hover, .nav-link.active {
            color: var(--primary) !important;
        }

        .user-pill {
            background: #f1f3f5;
            padding: 0.4rem 1rem;
            border-radius: 6px;
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .role-badge {
            font-size: 0.7rem;
            text-transform: uppercase;
            font-weight: 700;
            background: #e9ecef;
            color: #495057;
            padding: 1px 6px;
            border-radius: 4px;
        }

        .btn-logout {
            color: #666;
            font-size: 0.9rem;
            text-decoration: none;
            border: none;
            background: none;
            padding: 0;
            margin-left: 10px;
        }

        .btn-logout:hover {
            color: #dc3545;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light sticky-top shadow-sm">
            <div class="container">
                <a class="navbar-brand" asp-controller="Login" asp-action="Login">
                    CMS
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        @if (Context.Session.GetString("UserRole") != null)
                        {
                            var role = Context.Session.GetString("UserRole")?.ToLower();
                            @if (role == "admin")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Admin" asp-action="Index">Dashboard</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Admin" asp-action="Users">Manage Users</a>
                                </li>
                            }
                            else if (role == "patient")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Patient" asp-action="Index">My Health</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Patient" asp-action="Book">Book Appointment</a>
                                </li>
                            }
                            else if (role == "receptionist")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Receptionist" asp-action="Index">Daily Queue</a>
                                </li>
                            }
                            else if (role == "doctor")
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Doctor" asp-action="Index">Daily Queue</a>
                                </li>
                            }
                        }
                    </ul>
                    
                    @if (Context.Session.GetString("UserName") != null)
                    {
                        <div class="d-flex align-items-center gap-3">
                            <div class="user-pill d-none d-md-flex">
                                <div>
                                    <div class="fw-bold" style="font-size: 0.9rem; line-height: 1;">@Context.Session.GetString("UserName")</div>
                                    <div class="role-badge">@Context.Session.GetString("UserRole")</div>
                                </div>
                            </div>
                            <form asp-controller="Login" asp-action="Logout" method="post" class="m-0">
                                <button type="submit" class="btn-logout">Logout</button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
