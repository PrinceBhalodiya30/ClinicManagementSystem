@model List<ClinicManagementSystem.Models.QueueEntry>
@{
    ViewData["Title"] = "Daily Queue Management";
    string selectedDate = ViewBag.SelectedDate;
}

<div class="row align-items-center mb-4">
    <div class="col">
        <h2 class="fw-bold mb-0">Live Queue</h2>
        <p class="text-muted small">@DateTime.Parse(selectedDate).ToLongDateString()</p>
    </div>
    <div class="col-md-3">
        <form method="get">
            <label class="form-label small fw-bold text-muted">Filter Date</label>
            <input type="date" name="date" class="form-control" 
                   value="@selectedDate" onchange="this.form.submit()" />
        </form>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success border shadow-sm mb-4">
        @TempData["Success"]
    </div>
}

<div class="card border shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-3 py-3 text-muted fw-bold small">#</th>
                        <th class="py-3 text-muted fw-bold small">APPOINTMENT</th>
                        <th class="py-3 text-muted fw-bold small">STATUS</th>
                        <th class="pe-3 py-3 text-end text-muted fw-bold small">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in Model.OrderBy(x => x.TokenNumber))
                    {
                        <tr>
                            <td class="ps-3">
                                <span class="badge bg-primary rounded-circle py-2 px-3">
                                    @entry.TokenNumber
                                </span>
                            </td>
                            <td>
                                <span class="fw-bold">#@entry.AppointmentId</span>
                            </td>
                            <td>
                                @{
                                    var displayStatus = entry.Status.Replace("-", " ").Replace("_", " ");
                                }
                                <span class="badge border text-dark bg-light px-2 py-1 text-capitalize">
                                    @displayStatus
                                </span>
                            </td>
                            <td class="pe-3 text-end">
                                <div class="btn-group">
                                    @if (entry.Status == "waiting")
                                    {
                                        <form asp-action="UpdateStatus" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@entry.Id" />
                                            <input type="hidden" name="status" value="in-progress" />
                                            <input type="hidden" name="date" value="@selectedDate" />
                                            <button type="submit" class="btn btn-sm btn-outline-primary px-3">Start</button>
                                        </form>
                                        <form asp-action="UpdateStatus" method="post" class="d-inline ms-1">
                                            <input type="hidden" name="id" value="@entry.Id" />
                                            <input type="hidden" name="status" value="skipped" />
                                            <input type="hidden" name="date" value="@selectedDate" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger px-3">Skip</button>
                                        </form>
                                    }
                                    else if (entry.Status == "in-progress")
                                    {
                                        <form asp-action="UpdateStatus" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@entry.Id" />
                                            <input type="hidden" name="status" value="done" />
                                            <input type="hidden" name="date" value="@selectedDate" />
                                            <button type="submit" class="btn btn-sm btn-success px-3">Complete</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Locked</span>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted">
                                No patients in queue.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
