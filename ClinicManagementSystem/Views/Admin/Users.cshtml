@model List<ClinicManagementSystem.Models.UserInfo>
@{
    ViewData["Title"] = "Manage Users";
}

<div class="row align-items-center mb-4">
    <div class="col">
        <h2 class="fw-bold mb-0">Clinic Users</h2>
        <p class="text-muted">Manage all clinic accounts.</p>
    </div>
    <div class="col-auto">
        <a asp-action="CreateUser" class="btn btn-primary shadow-sm">
            Add User
        </a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border shadow-sm mb-4" role="alert">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border shadow-sm mb-4" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card border shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-3 py-3 text-muted fw-bold small">USER</th>
                        <th class="py-3 text-muted fw-bold small">ROLE</th>
                        <th class="py-3 text-muted fw-bold small">PHONE</th>
                        <th class="py-3 text-muted fw-bold small">ID</th>
                        <th class="pe-3 py-3 text-end text-muted fw-bold small">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-3 py-3">
                                <div class="fw-bold">@user.Name</div>
                                <div class="text-muted small">@user.Email</div>
                            </td>
                            <td>
                                <span class="badge border text-dark bg-light px-2 py-1 text-capitalize">
                                    @user.Role
                                </span>
                            </td>
                            <td><span class="text-muted small">@(string.IsNullOrEmpty(user.Phone) ? "N/A" : user.Phone)</span></td>
                            <td><span class="text-muted small">#@user.Id</span></td>
                            <td class="pe-3 text-end">
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-4 text-muted">
                                No users found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
